const express = require('express');
const axios = require('axios');
const https = require('https');
const path = require('path');
require('dotenv').config();

const app = express();
const PORT = process.env.PORT || 3000;

// 정적 파일 서빙
app.use(express.static(path.join(__dirname, 'public')));

// ============================================
// 한국투자증권 API 설정
// ============================================

const KIS_CONFIG = {
  APP_KEY: process.env.KIS_APP_KEY || 'your_app_key_here',
  APP_SECRET: process.env.KIS_APP_SECRET || 'your_app_secret_here',
  BASE_URL: 'https://openapi.koreainvestment.com:9443',  // ← 모의투자

//const KIS_CONFIG = {
//APP_KEY: process.env.KIS_APP_KEY || 'your_app_key_here',
//APP_SECRET: process.env.KIS_APP_SECRET || 'your_app_secret_here',
//BASE_URL: 'https://openapivts.koreainvestment.com:9443',


// 반도체 관련 종목 정의
const SEMICONDUCTOR_STOCKS = [
  { code: '005930', name: '삼성전자', market: 'KOSPI' },
  { code: '000660', name: 'SK하이닉스', market: 'KOSPI' },
  { code: '009540', name: '한미반도체', market: 'KOSPI' },
  { code: '078020', name: '이퓨전', market: 'KOSPI' },
  { code: '058970', name: '에이프로', market: 'KOSDAQ' },
];

// 액세스 토큰 캐시 (실제는 DB에 저장하는 것이 좋음)
let accessToken = null;
let tokenExpireTime = 0;

// ============================================
// 한국투자증권 API 함수들
// ============================================

/**
 * 액세스 토큰 발급
 */
async function getAccessToken() {
  try {
    // 토큰이 유효하면 캐시된 토큰 반환
    if (accessToken && Date.now() < tokenExpireTime) {
      return accessToken;
    }

const httpsAgent = new https.Agent({
  rejectUnauthorized: false,
});

const response = await axios.post(
  `${KIS_CONFIG.BASE_URL}/oauth2/tokenP`,
  {
    grant_type: 'client_credentials',
    appkey: KIS_CONFIG.APP_KEY,
    appsecret: KIS_CONFIG.APP_SECRET,
  },
  {
    headers: {
      'Content-Type': 'application/json',
    },
    httpsAgent: httpsAgent,
  }
);

    accessToken = response.data.access_token;
    // 토큰 만료 시간을 현재 시간 + 유효시간 - 1분으로 설정
    tokenExpireTime = Date.now() + (response.data.expires_in - 60) * 1000;

    console.log('✓ KIS 액세스 토큰 발급됨');
    return accessToken;
  } catch (error) {
    console.error('❌ 토큰 발급 실패:', error.message);
    throw error;
  }
}

/**
 * 국내주식 시세 조회
 */
async function getStockQuote(stockCode) {
  try {
    const token = await getAccessToken();

    console.log(`\n🔍 종목 조회: ${stockCode}`);

    const response = await axios.get(
      `${KIS_CONFIG.BASE_URL}/uapi/domestic-stock/v1/quotations/inquire-price`,
      {
        params: {
          fid_cond_mrkt_div_code: 'J',
          fid_input_iscd: stockCode.padStart(6, '0'),
        },
        headers: {
          'Content-Type': 'application/json; charset=utf-8',
          Authorization: `Bearer ${token}`,
          'appkey': KIS_CONFIG.APP_KEY,
          'appsecret': KIS_CONFIG.APP_SECRET,
          'tr-id': 'FHKST01010100',
        },
        httpsAgent: new (require('https')).Agent({
          rejectUnauthorized: false,
        }),
      }
    );

    console.log(`  응답 코드: ${response.status}`);
    console.log(`  응답 데이터:`, JSON.stringify(response.data, null, 2));

    if (response.data.rt_cd !== '0') {
      console.error(`  ❌ API 에러: ${response.data.msg1}`);
      throw new Error(response.data.msg1 || '조회 실패');
    }

    const data = response.data.output;
    const result = {
      code: stockCode,
      price: parseInt(data.stck_prpr),
      change: parseInt(data.prdy_ctrt),
      changePercent: parseFloat(data.prdy_clpr),
      volume: parseInt(data.acml_vol),
      amount: parseInt(data.acml_tr_pbmn),
      high: parseInt(data.stck_hgpr),
      low: parseInt(data.stck_lwpr),
      timestamp: new Date().toISOString(),
    };

    console.log(`  ✅ 성공:`, result);
    return result;

  } catch (error) {
    console.error(`\n❌ ${stockCode} 조회 실패:`);
    console.error(`  에러 메시지: ${error.message}`);
    if (error.response) {
      console.error(`  상태 코드: ${error.response.status}`);
      console.error(`  응답 데이터:`, JSON.stringify(error.response.data, null, 2));
    }
    return {
      code: stockCode,
      error: error.message,
      timestamp: new Date().toISOString(),
    };
  }
}
// ============================================
// API 엔드포인트
// ============================================

/**
 * 모든 반도체 종목 데이터 조회
 */
app.get('/api/semiconductors', async (req, res) => {
  try {
    const promises = SEMICONDUCTOR_STOCKS.map((stock) =>
      getStockQuote(stock.code)
        .then((quote) => ({
          ...stock,
          ...quote,
        }))
        .catch((error) => ({
          ...stock,
          error: error.message,
        }))
    );

    const results = await Promise.all(promises);
    res.json({
      success: true,
      data: results,
      timestamp: new Date().toISOString(),
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
    });
  }
});

/**
 * 특정 종목 데이터 조회
 */
app.get('/api/semiconductors/:code', async (req, res) => {
  try {
    const { code } = req.params;
    const stock = SEMICONDUCTOR_STOCKS.find((s) => s.code === code);

    if (!stock) {
      return res.status(404).json({
        success: false,
        error: '종목을 찾을 수 없습니다',
      });
    }

    const quote = await getStockQuote(code);
    res.json({
      success: true,
      data: {
        ...stock,
        ...quote,
      },
    });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
    });
  }
});

/**
 * 지원하는 종목 목록
 */
app.get('/api/stocks-list', (req, res) => {
  res.json({
    success: true,
    data: SEMICONDUCTOR_STOCKS,
  });
});

/**
 * 상태 체크
 */
app.get('/api/health', (req, res) => {
  res.json({
    success: true,
    status: 'Server is running',
    timestamp: new Date().toISOString(),
  });
});

// ============================================
// 서버 시작
// ============================================

app.listen(PORT, () => {
  console.log(`
╔════════════════════════════════════════╗
║   반도체 대시보드 서버 시작             ║
║   http://localhost:${PORT}                ║
╚════════════════════════════════════════╝
  `);
  console.log('📊 지원 종목:', SEMICONDUCTOR_STOCKS.map((s) => s.name).join(', '));
  console.log('\n⚠️  한국투자증권 API Key 설정 필요:');
  console.log('   .env 파일에 다음 정보 입력:');
  console.log('   KIS_APP_KEY=your_app_key');
  console.log('   KIS_APP_SECRET=your_app_secret');
});

module.exports = app;
